# ICPC HUE Next.js Frontend Environment Variables
PORT=3000
NODE_ENV=development

# Public Keys (Client Side)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
NEXT_PUBLIC_API_KEY=your_public_api_key
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_CF_CLIENT_ID=your_codeforces_client_id

# Server Side Secrets
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres?sslmode=disable
JWT_SECRET=your_jwt_secret
DB_ENCRYPTION_KEY=your_base64_encryption_key
BLIND_INDEX_SALT=your_base64_salt_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
GEMINI_API_KEY=your_gemini_api_key
CF_API_KEY=your_codeforces_api_key
CF_API_SECRET=your_codeforces_api_secret
CF_CLIENT_SECRET=your_codeforces_client_secret
JUDGE0_AUTH_TOKEN=your_judge0_token
