# ICPC HUE Express Backend Environment Variables
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres?sslmode=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT & API Secrets
JWT_SECRET=your_jwt_secret
API_SECRET_KEY=your_api_secret_key
ADMIN_API_KEY=your_admin_api_key
ADMIN_SECRET_TOKEN=your_admin_secret_token

# Encryption
DB_ENCRYPTION_KEY=your_base64_encryption_key
BLIND_INDEX_SALT=your_base64_salt_key

# reCAPTCHA
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_MIN_SCORE=0.5

# Email (SMTP)
SMTP_SERVER=localhost
SMTP_PORT=1025
SMTP_LOGIN=
SMTP_PASSWORD=
SENDER_EMAIL=noreply@icpchue.com
SENDER_NAME=ICPC HUE

# Judge0
JUDGE0_API_URL=http://localhost:2358
JUDGE0_AUTH_TOKEN=your_judge0_token

# External APIs
GEMINI_API_KEY=your_gemini_api_key
CF_API_KEY=your_codeforces_api_key
CF_API_SECRET=your_codeforces_api_secret
CF_CLIENT_SECRET=your_codeforces_client_secret
